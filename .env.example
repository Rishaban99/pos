# MongoDB Atlas connection string (replace YOUR-CLUSTER with your Atlas hostname, e.g. mycluster.abc123.mongodb.net)
DATABASE_URL="mongodb+srv://username:password@YOUR-CLUSTER.mongodb.net/hotel_pos"

# Initial super admin bootstrap (required on first run when no staff accounts exist).
# Copy this file to .env and set secure values before starting the dev server.
NEXT_PUBLIC_INITIAL_SUPER_ADMIN_USERNAME=admin
INITIAL_SUPER_ADMIN_PASSWORD=change-me
NEXT_PUBLIC_INITIAL_SUPER_ADMIN_NAME=Super Admin
